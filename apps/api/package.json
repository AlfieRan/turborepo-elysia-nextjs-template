{
	"name": "@repo/api",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"main": "./dist/index.js",
	"types": "./.types/index.d.ts",
	"exports": {
		".": {
			"types": "./.types/index.d.ts"
		}
	},
	"scripts": {
		"dev": "bun --hot src/index.ts & tsc --watch --preserveWatchOutput",
		"build": "bun build src/index.ts --target bun --outdir ./dist",
		"build:types": "tsc",
		"start": "NODE_ENV=production bun dist/index.js",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"lint": "eslint --max-warnings 0 && prettier --check \"**/*.{ts,tsx,md}\"",
		"db:start": "supabase start",
		"db:stop": "supabase stop",
		"db:reset": "supabase reset",
		"db:generate": "bunx --bun drizzle-kit generate",
		"db:migrate": "bunx supabase migration up",
		"db:push": "bunx --bun drizzle-kit push",
		"db:studio": "bunx --bun drizzle-kit studio"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@repo/shared": "*",
		"@supabase/supabase-js": "^2.95.3",
		"drizzle-orm": "^0.45.1",
		"elysia": "^1.4.23",
		"postgres": "^3.4.8",
		"posthog-node": "^5.24.15",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@repo/eslint-config": "*",
		"@repo/ts-config": "*",
		"@types/bun": "^1.3.8",
		"@types/node": "^22.15.3",
		"drizzle-kit": "^0.31.9",
		"eslint": "^9.39.1",
		"supabase": "^2.76.16",
		"typescript": "5.9.2"
	}
}
