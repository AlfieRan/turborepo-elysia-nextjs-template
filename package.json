{
	"name": "repo",
	"private": true,
	"scripts": {
		"db:start": "turbo run db:start",
		"db:stop": "turbo run db:stop",
		"db:reset": "turbo run db:reset",
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"docker:build:api": "docker build -f ./apps/api/image/Dockerfile -t repo-api:local ."
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.1.18",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"prettier": "^3.7.4",
		"tailwindcss": "^4.1.18",
		"tailwindcss-animate": "^1.0.7",
		"turbo": "^2.8.3",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": "24"
	},
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"dependencies": {
		"@elysiajs/eden": "^1.4.8"
	}
}
